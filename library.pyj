from system.pyj.minescript import *

minecraft = JavaClass("net.minecraft.client.Minecraft").getInstance()
minescript = JavaClass("net.minescript.common.Minescript")

class XaeroHelper:
    BuiltInHudModules = None
    
    @staticmethod
    def is_mod_loaded() -> bool:
        if XaeroHelper.BuiltInHudModules is not None:
            return True
        
        try:
            # xaero_minimap_session = JavaClass("xaero.minimap.XaeroMinimap").instance.createSession() #xaero.common.XaeroMinimapSession
            # XaeroHelper.IXaeroMinimap = xaero_minimap_session.getModMain()  #aero.minimap.XaeroMinimapFabric
            XaeroHelper.BuiltInHudModules = JavaClass("xaero.hud.minimap.BuiltInHudModules")
        except Exception as e:
            return False
        return True
    
    # @staticmethod
    # def get_minimap():
    #     if not XaeroHelper.is_mod_loaded():
    #         return None
    #     return XaeroHelper.IXaeroMinimap.getMinimap() #xaero.hud.minimap.Minimap
    
    @staticmethod
    def get_current_minimap_session() -> JavaObject | None: #xaero.hud.minimap.module.MinimapSession
        if not XaeroHelper.is_mod_loaded():
            return None
        return XaeroHelper.BuiltInHudModules.MINIMAP.getCurrentSession() #xaero.common.XaeroMinimapSession

    @staticmethod
    def get_current_world_manager() -> JavaObject | None: #xaero.hud.minimap.world.MinimapWorldManager
        if not XaeroHelper.is_mod_loaded():
            return None
        return XaeroHelper.get_current_minimap_session().getWorldManager()
    
    @staticmethod
    def get_current_world() -> JavaObject | None: #xaero.hud.minimap.world.MinimapWorld
        if not XaeroHelper.is_mod_loaded():
            return None
        return XaeroHelper.get_current_world_manager().getCurrentWorld()
    
    @staticmethod
    def get_current_waypoint_set() -> JavaObject | None: #xaero.hud.minimap.waypoint.set.WaypointSet
        if not XaeroHelper.is_mod_loaded():
            return None
        
        return XaeroHelper.get_current_world().getCurrentWaypointSet()
    
    @staticmethod
    def get_current_waypoint_set_name() -> str | None:
        if not XaeroHelper.is_mod_loaded():
            return None
        
        return XaeroHelper.get_current_waypoint_set().getName()

    @staticmethod
    def get_current_set_waypoints() -> List[Waypoint] | None:
        if not XaeroHelper.is_mod_loaded():
            return None
        
        waypoints =  XaeroHelper.get_current_waypoint_set().getWaypoints()
        
        waypoint_list = []
        for waypoint_i in range(waypoints.size()):
            waypoint = waypoints.get(waypoint_i)
            waypoint_list.append(Waypoint(
                name=waypoint.getName(),
                initials=waypoint.getInitials(),
                x=waypoint.getX(),
                y=waypoint.getY(),
                z=waypoint.getZ(),
                index = waypoint_i,
                set_name = XaeroHelper.get_current_waypoint_set_name()
            ))
        return JavaArray(tuple(waypoint_list))
    
    @staticmethod
    def add_waypoint_to_current_set(name: str, x: float|int, y: float|int, z: float|int, initials: str) -> bool | None:
        if not XaeroHelper.is_mod_loaded():
            return None

        waypoint_set = XaeroHelper.get_current_waypoint_set()

        WaypointClass = JavaClass("xaero.common.minimap.waypoints.Waypoint")
        waypoint = WaypointClass(int(x), int(y), int(z), name, initials, 0)
        waypoint_set.add(waypoint)
        return True
    
    @staticmethod
    def remove_waypoint_from_current_set(waypoint: Waypoint | int) -> bool:
        if not XaeroHelper.is_mod_loaded():
            return None

        waypoint_set = XaeroHelper.get_current_waypoint_set()
        if isinstance(waypoint, int):
            waypoint_set.remove(waypoint)
            return True

        waypoint_set.remove(waypoint.index)
        return True
    
    @staticmethod
    def get_waypoint_from_current_set(waypoint: Waypoint | int) -> Waypoint | None:
        if not XaeroHelper.is_mod_loaded():
            return None

        waypoint_set = XaeroHelper.get_current_waypoint_set()
        if isinstance(waypoint, int):
            return waypoint_set.get(waypoint)

        return waypoint_set.get(waypoint.index)
    
    @staticmethod
    def get_current_waypoint_set_count() -> int | None:
        if not XaeroHelper.is_mod_loaded():
            return None
        return XaeroHelper.get_current_waypoint_set().size()

class Waypoint:
    def __init__(self, name: str, initials: str, x: float, y: float, z: float, index: int = 0, set_name: str = ""):
        self.name = name
        self.initials = initials
        self.x = x
        self.y = y
        self.z = z
        self.index = index
        self.set_name = set_name

class GuiWidget:
    def __init__(self, x: int, y: int, width: int, height: int, message: str, active: bool, visible: bool, focused: bool, java_object: JavaObject):
        self.x = x
        self.y = y
        self.width = width
        self.height = height
        self.message = message
        self.active = active
        self.visible = visible
        self.focused = focused
        self.java_object = java_object

class BookScreenHelper:
    @staticmethod
    def is_edit_book_screen() -> bool:
        current_screen = ScreenHelper.get_current_screen()
        if current_screen is None:
            return False
        return UtilHelper.get_class_name(current_screen) == "net.minecraft.client.gui.screens.inventory.BookEditScreen"
    
    @staticmethod
    def is_view_book_screen() -> bool:
        current_screen = ScreenHelper.get_current_screen()
        if current_screen is None:
            return False
        return UtilHelper.get_class_name(current_screen) == "net.minecraft.client.gui.screens.inventory.BookViewScreen"
    
    @staticmethod
    def is_sign_book_screen() -> bool:
        current_screen = ScreenHelper.get_current_screen()
        if current_screen is None:
            return False
        return UtilHelper.get_class_name(current_screen) == "net.minecraft.client.gui.screens.inventory.BookSignScreen"
    
    @staticmethod
    def is_book_screen() -> bool:
        return BookScreenHelper.is_edit_book_screen() or BookScreenHelper.is_view_book_screen() or BookScreenHelper.is_sign_book_screen()
    
    @staticmethod
    def _get_pages() -> JavaObject | None:
        if not BookScreenHelper.is_book_screen():
            return None
        
        current_screen = ScreenHelper.get_current_screen()
        
        if BookScreenHelper.is_edit_book_screen() or BookScreenHelper.is_sign_book_screen():
            return ReflectionHelper.get_private_field(current_screen, "pages")
        elif BookScreenHelper.is_view_book_screen():
            book_access = ReflectionHelper.get_private_field(current_screen, "bookAccess")
            return ReflectionHelper.get_private_field(book_access, "pages")
    
    @staticmethod
    def get_page_count() -> int | None:
        if not BookScreenHelper.is_book_screen():
            return None
        
        return BookScreenHelper._get_pages().size() # type: ignore
    
    @staticmethod
    def get_current_page_index() -> int | None:
        if not BookScreenHelper.is_book_screen() or BookScreenHelper.is_sign_book_screen():
            return None
        
        current_screen = ScreenHelper.get_current_screen()
        return ReflectionHelper.get_private_field(current_screen, "currentPage")
    
    @staticmethod
    def is_last_page() -> bool | None:
        if not BookScreenHelper.is_book_screen():
            return None
        
        current_page = BookScreenHelper.get_current_page_index()
        page_count = BookScreenHelper.get_page_count()
        
        return current_page == (page_count - 1) # type: ignore
    
    @staticmethod
    def page_forward() -> None:
        if not BookScreenHelper.is_book_screen():
            return None
        
        current_screen = ScreenHelper.get_current_screen()
        ReflectionHelper.invoke_private_method(current_screen, "pageForward")

    @staticmethod
    def page_back() -> None:
        if not BookScreenHelper.is_book_screen():
            return None
        
        current_screen = ScreenHelper.get_current_screen()
        ReflectionHelper.invoke_private_method(current_screen, "pageBack")
    
    @staticmethod
    def sign_editable_book(title: str) -> bool:
        if not BookScreenHelper.is_edit_book_screen() and not BookScreenHelper.is_sign_book_screen():
            return False
        
        current_screen = ScreenHelper.get_current_screen()
        sign_screen = None
        
        if BookScreenHelper.is_edit_book_screen():
            # Get the sign screen instance from the edit screen
            sign_screen = ReflectionHelper.get_private_field(current_screen, "signScreen")
            ReflectionHelper.invoke_private_method(current_screen, "saveChanges")
            ScreenHelper.set_current_screen(sign_screen)
        else:
            # We are already on the sign screen
            sign_screen = current_screen
            
        if sign_screen is None:
            return False
            
        # Set the title and finalize the book
        title_box = ReflectionHelper.get_private_field(sign_screen, "titleBox")
        if title_box is not None:
            title_box.setValue(title)
            ReflectionHelper.invoke_private_method(sign_screen, "saveChanges")
            ScreenHelper.set_current_screen(None)
            return True
            
        return False
    
    @staticmethod
    def save_editable_book() -> bool:
        if not BookScreenHelper.is_edit_book_screen():
            return False
        
        current_screen = ScreenHelper.get_current_screen()
        ReflectionHelper.invoke_private_method(current_screen, "saveChanges")
        ScreenHelper.set_current_screen(None)
        return True
class Vec3:
    def __init__(self, x: float, y: float, z: float):
        self.x = x
        self.y = y
        self.z = z
        
class Vec2:
    def __init__(self, x: float, y: float):
        self.x = x
        self.y = y

class WindowSize:
    def __init__(self, width: float, height: float):
        self.width = width
        self.height = height

class MappingsHelper:
    mappings: JavaObject = minescript.mappingsLoader.get()

    @staticmethod
    def get_runtime_class_name(pretty_class_name: str) -> str:
        return MappingsHelper.mappings.getRuntimeClassName(pretty_class_name)
    @staticmethod
    def get_pretty_class_name(runtime_class_name: str) -> str:
        return MappingsHelper.mappings.getPrettyClassName(runtime_class_name)
    @staticmethod
    def get_runtime_field_name(clazz: JavaClass, pretty_field_name: str) -> str:
        return MappingsHelper.mappings.getRuntimeFieldName(clazz, pretty_field_name)
    @staticmethod
    def get_pretty_field_names(clazz: JavaClass) -> JavaSet[str]:
        return MappingsHelper.mappings.getPrettyFieldNames(clazz)
    @staticmethod
    def get_runtime_method_names(clazz: JavaClass, pretty_method_name: str) -> JavaSet[str]:
        return MappingsHelper.mappings.getRuntimeMethodNames(clazz, pretty_method_name)
    @staticmethod
    def get_pretty_method_names(clazz: JavaClass) -> JavaSet[str]:
        return MappingsHelper.mappings.getPrettyMethodNames(clazz)


class ReflectionHelper:
    _method_cache = {}

    @staticmethod
    def is_instance_of(instance: JavaObject, class_name: str) -> bool:
        if instance is None:
            return False
            
        current_class = instance.getClass()
        while current_class is not None:
            if MappingsHelper.get_pretty_class_name(current_class.getName()) == class_name:
                return True
            current_class = current_class.getSuperclass()
            
        return False

    @staticmethod
    def _get_declared_field_accessible(instance, pretty_field_name):
        current_class = instance.getClass()

        while current_class is not None:
            try:
                runtime_field_name = MappingsHelper.get_runtime_field_name(
                    current_class,
                    pretty_field_name
                )

                field = current_class.getDeclaredField(runtime_field_name)
                field.setAccessible(True)

                return field
            except Exception:
                current_class = current_class.getSuperclass()

        return None

    @staticmethod
    def get_private_field(instance, pretty_field_name) -> Any|None:
        field = ReflectionHelper._get_declared_field_accessible(
            instance,
            pretty_field_name
        )

        return field.get(instance) if field is not None else None

    @staticmethod
    def set_private_field(instance, pretty_field_name, value) -> bool:
        field = ReflectionHelper._get_declared_field_accessible(
            instance,
            pretty_field_name
        )

        if field is not None:
            field.set(instance, value)
            return True

        return False
    
    @staticmethod
    def get_declared_method_accessible(instance, pretty_method_name):
        current_class = instance.getClass()
        cache_key = (current_class, pretty_method_name)

        method = ReflectionHelper._method_cache.get(cache_key)
        if method is not None:
            return method

        while current_class is not None:
            try:
                runtime_method_names = MappingsHelper.get_runtime_method_names(
                    current_class,
                    pretty_method_name
                )

                if runtime_method_names is None or runtime_method_names.isEmpty():
                    current_class = current_class.getSuperclass()
                    continue

                for method in current_class.getDeclaredMethods():
                    if runtime_method_names.contains(method.getName()):
                        method.setAccessible(True)
                        ReflectionHelper._method_cache[cache_key] = method
                        return method

            except Exception as e:
                print("Class failed:", e)

            current_class = current_class.getSuperclass()

        return None

    @staticmethod
    def invoke_private_method(instance, pretty_method_name, *args):
        method = ReflectionHelper.get_declared_method_accessible(
            instance,
            pretty_method_name
        )

        if method is None:
            return None

        return method.invoke(instance, JavaArray(args))
        
class EnchantmentInfo:
    def __init__(self, enchantment_id: str, name: str, level: int, costs: int):
        self.id = enchantment_id
        self.name = name
        self.level = level
        self.costs = costs
        
class ContainerHelper:
    ClickType = JavaClass("net.minecraft.world.inventory.ClickType")
    
    @staticmethod
    def get_container() -> JavaObject | None:
        return minecraft.player.containerMenu

    @staticmethod
    def get_slot_screen_position(slot: int) -> Vec2 | None:
        container = ContainerHelper.get_container()
        screen = ScreenHelper.get_current_screen()

        if container is None or screen is None:
            return None

        slot = container.getSlot(slot)

        # Calculate relative to the container's screen origin
        bounds = ScreenHelper.get_container_bounds()
        if bounds is None:
            return None

        gui_x = bounds.left + slot.x + 8
        gui_y = bounds.top + slot.y + 8

        return WindowHelper.get_screen_position(gui_x, gui_y)
    
    @staticmethod
    def _resolve_click_type(click_type) -> JavaObject:
        if click_type is None:
            return ContainerHelper.ClickType.PICKUP

        if type(click_type) is str:
            for value in ContainerHelper.ClickType.values():
                if value.name() == click_type:
                    return value

        return click_type

    @staticmethod
    def get_container_id() -> int:
        container = ContainerHelper.get_container()
        if container is None:
            return -1
        return container.containerId

    @staticmethod
    def get_container_class_name() -> str:
        container = ContainerHelper.get_container()
        if container is None:
            return ""
        return UtilHelper.get_class_name(container)
    
    @staticmethod
    def raw_click(slot, button_or_slot=0, click_type=None) -> bool:
        click_type = ContainerHelper._resolve_click_type(click_type)
        container_id = ContainerHelper.get_container_id()
        if container_id < 0:
            return False

        minecraft.gameMode.handleInventoryMouseClick(
            container_id,
            slot,
            button_or_slot,
            click_type,
            minecraft.player
        )
        return True

    @staticmethod
    def click_button(button_id) -> bool:
        container_id = ContainerHelper.get_container_id()
        if container_id < 0:
            return False

        minecraft.gameMode.handleInventoryButtonClick(
            container_id,
            button_id
        )
        return True
    
    @staticmethod
    def click_slot(slot, button=0) -> bool:
        return ContainerHelper.raw_click(slot, button, ContainerHelper.ClickType.PICKUP)

    @staticmethod
    def shift_click_slot(slot) -> bool:
        return ContainerHelper.raw_click(slot, 0, ContainerHelper.ClickType.QUICK_MOVE)

    @staticmethod
    def click_swap_with_hotbar(slot, hotbar_slot) -> bool:
        return ContainerHelper.raw_click(slot, hotbar_slot, ContainerHelper.ClickType.SWAP)

    @staticmethod
    def pickup_swap_container(slot_a, slot_b) -> bool:
        # Pick up the stack from the source slot once, then right-click the
        # destination slot to place the items, and finally return
        # the remainder to the source slot. (if it has any)
        if not ContainerHelper.raw_click(slot_a, 0, ContainerHelper.ClickType.PICKUP):
            return False
        if not ContainerHelper.raw_click(slot_b, 0, ContainerHelper.ClickType.PICKUP):
            return False
        return ContainerHelper.raw_click(slot_a, 0, ContainerHelper.ClickType.PICKUP)

    @staticmethod
    def _get_item_by_slot(items: List[ItemStack], slot: int) -> ItemStack | None:
        for item in items:
            if item.slot == slot:
                return item
        return None

    @staticmethod
    def get_container_slot(slot: int) -> ItemStack | None:
        return ContainerHelper._get_item_by_slot(container_get_items(), slot)

    @staticmethod
    def get_inventory_slot(slot: int) -> ItemStack | None:
        return ContainerHelper._get_item_by_slot(player_inventory(), slot)
    
    @staticmethod
    def get_item_stack_by_inventory_slot(slot: int) -> JavaObject | None:
        return minecraft.player.getInventory().getItem(slot)

    @staticmethod
    def get_item_stack_by_container_slot(slot: int) -> JavaObject | None:
        return ContainerHelper.get_container().getSlot(slot).getItem()

    @staticmethod
    def _has_item_id(items: List[ItemStack], item_id: str) -> List[ItemStack]:
        found_item_stacks = []
        for item in items:
            if item.item == item_id:
                found_item_stacks.append(item)
        return found_item_stacks
    
    @staticmethod
    def container_find_item_id(item_id: str) -> list[ItemStack]:
        return ContainerHelper._has_item_id(container_get_items(), item_id)
    
    @staticmethod
    def inventory_find_item_id(item_id: str) -> list[ItemStack]:
        return ContainerHelper._has_item_id(player_inventory(), item_id)

    @staticmethod
    def get_inventory_selected_hotbar_slot() -> int:
        return int(ReflectionHelper.get_private_field(minecraft.player.getInventory(), "selected"))
    
    @staticmethod
    def get_inventory_free_slot() -> int | None:
        return minecraft.player.getInventory().getFreeSlot()
    
    @staticmethod
    def _resolve_enchantment_button_index(enchantment_apply_type: str) -> int | None:
        enchantment_buttons = {
            "bottom": 0,
            "middle": 1,
            "top": 2,
        }

        if enchantment_apply_type not in enchantment_buttons:
            return None

        return enchantment_buttons[enchantment_apply_type]

    @staticmethod
    def enchantment_table_apply_enchant(enchantment_apply_type) -> bool:
        if (ContainerHelper.get_container_class_name() != "net.minecraft.world.inventory.EnchantmentMenu"):
            return False
   
        button_id = ContainerHelper._resolve_enchantment_button_index(enchantment_apply_type)
        if button_id is None:
            return False
        
        return ContainerHelper.click_button(button_id)
    
    @staticmethod
    def enchantment_table_get_enchant_info(enchantment_apply_type) -> EnchantmentInfo|None:
        if (ContainerHelper.get_container_class_name() != "net.minecraft.world.inventory.EnchantmentMenu"):
            return None

        index = ContainerHelper._resolve_enchantment_button_index(enchantment_apply_type)
        if index is None:
            return None
        
        container = ContainerHelper.get_container()
        enchantment_id = container.enchantClue[index]
        
        enchantment_holder = RegistryHelper.get_holder_by_numeric_id(
            RegistryHelper.Registries.ENCHANTMENT,
            enchantment_id,
        )

        if enchantment_holder is None:
            return None
        
        enchantment_level = container.levelClue[index]
        enchantment_cost = container.costs[index]
        enchantment_name = enchantment_holder.key().identifier().toString()
        
        return EnchantmentInfo(
            enchantment_id=enchantment_id,
            name=enchantment_name,
            level=enchantment_level,
            costs=enchantment_cost,
        ) 

class ItemsHelper:
    Item = JavaClass("net.minecraft.world.item.Item")
    Items = JavaClass("net.minecraft.world.item.Items")
    Identifier = JavaClass("net.minecraft.resources.Identifier")
    DataComponents = JavaClass("net.minecraft.core.component.DataComponents")
    ItemStackClass = JavaClass("net.minecraft.world.item.ItemStack")

    @staticmethod
    def _resolve_to_item_stack(item: JavaObject | str | int) -> JavaObject:
        """Convert item_id (str), numeric_id (int), or JavaObject to ItemStack JavaObject."""
        # Handle int and str first (convert to Item)
        if isinstance(item, int):
            item_obj = ItemsHelper.Item.byId(item)
            return item_obj.getDefaultInstance()
        elif isinstance(item, str):
            item_obj = RegistryHelper.get_by_id(RegistryHelper.BuiltInRegistries.ITEM, item)
            return item_obj.getDefaultInstance()
        
        class_name = UtilHelper.get_class_name(item)
        if class_name == "net.minecraft.world.item.Item":
            return item.getDefaultInstance()
        elif class_name == "net.minecraft.world.item.ItemStack":
            return item
        else:
            raise TypeError(f"Expected Item or ItemStack, got {class_name}")

    @staticmethod
    def _resolve_to_item(item: JavaObject | str | int) -> JavaObject:
        """Convert numeric_id (int), item_id (str), or JavaObject to Item JavaObject."""
        if isinstance(item, int):
            return ItemsHelper.Item.byId(item)
        elif isinstance(item, str):
            return RegistryHelper.get_by_id(RegistryHelper.BuiltInRegistries.ITEM,item)
        
        class_name = UtilHelper.get_class_name(item)
        if class_name == "net.minecraft.world.item.Item":
            return item
        elif class_name == "net.minecraft.world.item.ItemStack":
            return item.getItem()
        else:
            raise TypeError(f"Expected Item or ItemStack, got {class_name}")

    @staticmethod
    def get_item_id(item: JavaObject | str | int) -> str | None:
        """Get the item ID (minecraft namespace identifier) for an item."""
        item_obj = ItemsHelper._resolve_to_item(item)
        return RegistryHelper.get_registry_path(RegistryHelper.BuiltInRegistries.ITEM, item_obj)

    @staticmethod
    def get_numeric_id(item: JavaObject | str | int) -> int:
        """Get the numeric registry ID for an item."""
        item_obj = ItemsHelper._resolve_to_item(item)
        return ItemsHelper.Item.getId(item_obj)

    @staticmethod
    def get_display_name(item: JavaObject | str | int, use_custom_name: bool = False) -> str | None:
        """Get the display name of an item or itemstack."""
        stack = ItemsHelper._resolve_to_item_stack(item)
        if use_custom_name:
            return stack.getHoverName().getString()
        return stack.getDisplayName().getString()

    @staticmethod
    def get_count(item: JavaObject | str | int) -> int:
        """Get the stack count. Returns 1 for single items, actual count for itemstacks."""
        stack = ItemsHelper._resolve_to_item_stack(item)
        return stack.getCount()

    @staticmethod
    def get_max_stack_size(item: JavaObject | str | int) -> int:
        """Get the maximum stack size for an item."""
        stack = ItemsHelper._resolve_to_item_stack(item)
        return stack.getMaxStackSize()

    @staticmethod
    def get_item_stack_java_object(item: JavaObject | str | int) -> JavaObject:
        """Get the ItemStack JavaObject."""
        return ItemsHelper._resolve_to_item_stack(item)

    @staticmethod
    def get_item_java_object(item: JavaObject | str | int) -> JavaObject:
        """Get the Item JavaObject."""
        return ItemsHelper._resolve_to_item(item)

    @staticmethod
    def get_json(item: JavaObject | str | int) -> str:
        stack = ItemsHelper._resolve_to_item_stack(item)

        json_element = RegistryHelper._encodeStart(ItemsHelper.ItemStackClass,stack,)
        return _JsonHelper.dumps(json_element)
    
    @staticmethod
    def get_components(item: JavaObject | str | int) -> str:
        components = _JsonHelper.get(ItemsHelper.get_json(item),"components",)
        return _JsonHelper.dumps(components)


import system.pyj.json as json

class _JsonHelper:
    JsonParser = JavaClass("com.google.gson.JsonParser")
    JsonOps = JavaClass("com.mojang.serialization.JsonOps")

    @staticmethod
    def loads(data: str):
        """Parse a JSON string into a Gson JsonElement."""
        return json.loads(data)
    
    @staticmethod
    def parse(data: str):
        """Parse a JSON string into a Gson JsonElement."""
        return _JsonHelper.JsonParser.parseString(data)

    @staticmethod
    def dumps(element) -> str:
        return element.toString()

    @staticmethod
    def get(data: str, key: str):
        element = _JsonHelper.parse(data)

        if not element.isJsonObject():
            raise TypeError(
                "JSON root must be a JsonObject"
            )

        value = element.get(key)

        if value is None or value.isJsonNull():
            return None

        return json._from_json(value)

class FishingHelper:
    ROD: JavaObject = ItemsHelper.Items.FISHING_ROD

    @staticmethod
    def _get_fishing_hook() -> JavaObject | None:
