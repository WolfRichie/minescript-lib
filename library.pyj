class MerchantHelper:
    MerchantOffers = JavaClass("net.minecraft.world.item.trading.MerchantOffers")
    ServerboundSelectTradePacket = JavaClass("net.minecraft.network.protocol.game.ServerboundSelectTradePacket")

    @staticmethod
    def is_container_merchant() -> bool:
        container_name = ContainerHelper.get_container_class_name()
        return container_name == "net.minecraft.world.inventory.MerchantMenu"
    
    @staticmethod
    def get_offers_json():
        if not MerchantHelper.is_container_merchant():
            return None
        
        container = ContainerHelper.get_container()
        offers = container.getOffers()
        
        json_element = RegistryHelper._encodeStart(
            MerchantHelper.MerchantOffers,
            offers
        )
        recipes = json_element.get("Recipes")
        
        return _JsonHelper.dumps(recipes)

    @staticmethod
    def set_selected_trade_index(index: int) -> bool:
        if not MerchantHelper.is_container_merchant():
            return False
        
        container = ContainerHelper.get_container()
        
        container.setSelectionHint(index)
        container.tryMoveItems(index)
        minecraft.getConnection().send(MerchantHelper.ServerboundSelectTradePacket(index));
        return True
    
    @staticmethod
    def get_xp() -> int | None:
        if not MerchantHelper.is_container_merchant():
            return None
        
        container = ContainerHelper.get_container()
        return container.getTraderXp()
    
    @staticmethod
    def get_total_xp_needed_for_level_up() -> int | None:
        if not MerchantHelper.is_container_merchant():
            return None
        
        container = ContainerHelper.get_container()
        return container.getFutureTraderXp()
    
    @staticmethod
    def get_level() -> int | None:
        if not MerchantHelper.is_container_merchant():
            return None
        
        container = ContainerHelper.get_container()
        return container.getTraderLevel()

class ContainerBounds:
    def __init__(self, left: int, top: int, width: int, height: int):
        self.left = left
        self.top = top
        self.width = width
        self.height = height

class ScreenHelper:
    PauseScreen = JavaClass("net.minecraft.client.gui.screens.PauseScreen")
    InventoryScreen = JavaClass("net.minecraft.client.gui.screens.inventory.InventoryScreen")
    Component = JavaClass("net.minecraft.network.chat.Component")
    SystemToast = JavaClass("net.minecraft.client.gui.components.toasts.SystemToast")
    AlertScreen = JavaClass("net.minecraft.client.gui.screens.AlertScreen")

    @staticmethod
    def set_current_screen(screen: JavaObject) -> None:
        minecraft.setScreen(screen)
    
    @staticmethod
    def get_current_screen() -> JavaObject | None:
        return minecraft.screen
    
    @staticmethod
    def get_current_screen_class_name() -> str:
        if minecraft.screen is None:
            return None
        return UtilHelper.get_class_name(minecraft.screen)
    
    @staticmethod
    def get_container_bounds() -> ContainerBounds | None:
        """For container screens, returns leftPos, topPos, imageWidth, imageHeight."""
        screen = ScreenHelper.get_current_screen()
        if screen is None:
            return None
        
        try:
            return ContainerBounds(
                left=ReflectionHelper.get_private_field(screen, "leftPos"),
                top=ReflectionHelper.get_private_field(screen, "topPos"),
                width=ReflectionHelper.get_private_field(screen, "imageWidth"),
                height=ReflectionHelper.get_private_field(screen, "imageHeight")
            )
        except:
            return None
    
    @staticmethod
    def close_current_screen(with_close_container_packet: bool = True) -> None:
        if with_close_container_packet:
            minecraft.player.closeContainer()
        else:
            minecraft.setScreen(None)

    @staticmethod
    def open_pause_screen() -> None:
        ScreenHelper.set_current_screen(ScreenHelper.PauseScreen())

    @staticmethod
    def open_inventory_screen() -> None:
        ScreenHelper.set_current_screen(ScreenHelper.InventoryScreen(minecraft.player))

    @staticmethod
    def show_toast(title: str, desc: str, display_time: float = 5000.0):
        toast_manager = minecraft.getToastManager()
        _title = ScreenHelper.Component.literal(title)
        _desc = ScreenHelper.Component.literal(desc)
        system_toast_id = ScreenHelper.SystemToast.SystemToastId()
        
        ReflectionHelper.set_private_field(system_toast_id, "displayTime", display_time)
        
        toast_manager.addToast(ScreenHelper.SystemToast.multiline(minecraft, system_toast_id, _title, _desc))
    
    @staticmethod
    def open_alert_screen(title_text: str, message_text: str, ok_button_text: str = "OK"):
        def ok_pressed():
            ScreenHelper.close_current_screen()
            managed_callback.cancel()
        
        managed_callback = ManagedCallback(ok_pressed)
        title_literal = ScreenHelper.Component.literal(title_text)
        message_literal = ScreenHelper.Component.literal(message_text)
        ok_button_literal = ScreenHelper.Component.literal(ok_button_text)
        ScreenHelper.set_current_screen(ScreenHelper.AlertScreen(managed_callback, title_literal, message_literal, ok_button_literal, True))
        
    @staticmethod
    def is_any_toast_showing() -> bool:
        toast_manager = minecraft.getToastManager()
        return not toast_manager.visibleToasts.isEmpty()
class WidgetScreenHelper:
    @staticmethod
    def _wrap_abstract_widget(java_object) -> GuiWidget | None:
        if not ReflectionHelper.is_instance_of(java_object, "net.minecraft.client.gui.components.AbstractWidget"):
            return None
        
        message = java_object.getMessage()
        return GuiWidget(
            x=java_object.getX(),
            y=java_object.getY(),
            width=java_object.getWidth(),
            height=java_object.getHeight(),
            message=message.getString() if message else "",
            active=java_object.active,
            visible=java_object.visible,
            focused=java_object.isFocused(),
            java_object=java_object
        )

    @staticmethod
    def get_widgets() -> List[GuiWidget] | None:
        screen = ScreenHelper.get_current_screen()
        if screen is None:
            return None
        
        children = ReflectionHelper.get_private_field(screen, "children")
        if children is None:
            return None
            
        widget_list = []
        for i in range(children.size()):
            wrapped = WidgetScreenHelper._wrap_abstract_widget(children.get(i))
            if wrapped:
                widget_list.append(wrapped)
        return JavaArray(tuple(widget_list))

    @staticmethod
    def _create_mouse_event(x: float, y: float, button: int) -> JavaObject:
        MouseButtonInfo = JavaClass("net.minecraft.client.input.MouseButtonInfo")
        MouseButtonEvent = JavaClass("net.minecraft.client.input.MouseButtonEvent")
        return MouseButtonEvent(float(x), float(y), MouseButtonInfo(button, 0))

    @staticmethod
    def click_widget(widget: GuiWidget | JavaObject) -> bool:
        """Simulates a click on a widget."""
        java_obj = widget.java_object if isinstance(widget, GuiWidget) else widget
        if java_obj is None:
            return False
        
        x = java_obj.getX() + (java_obj.getWidth() / 2)
        y = java_obj.getY() + (java_obj.getHeight() / 2)
        
        return java_obj.mouseClicked(WidgetScreenHelper._create_mouse_event(x, y, 0), False)

    @staticmethod
    def click_at(x: float, y: float, button: int = 0) -> bool:
        """Simulates a click at specific GUI coordinates."""
        screen = ScreenHelper.get_current_screen()
        if screen is None:
            return False
        
        return screen.mouseClicked(WidgetScreenHelper._create_mouse_event(x, y, button), False)

    @staticmethod
    def get_renderables() -> List[GuiWidget | JavaObject] | None:
        screen = ScreenHelper.get_current_screen()
        if screen is None:
            return None
        
        renderables = ReflectionHelper.get_private_field(screen, "renderables")
        if renderables is None:
            return None
            
        renderable_list = []
        for i in range(renderables.size()):
            r = renderables.get(i)
            wrapped = WidgetScreenHelper._wrap_abstract_widget(r)
            if wrapped:
                renderable_list.append(wrapped)
            else:
                renderable_list.append(r)
        return JavaArray(tuple(renderable_list))

    @staticmethod
    def get_widget_by_message(text: str, match_case: bool = False) -> GuiWidget | None:
        widgets = WidgetScreenHelper.get_widgets()
        if widgets is None:
            return None
        
        if not match_case:
            text = text.lower()
            
        for widget in widgets:
            message_text = widget.message
            if not match_case:
                if text in message_text.lower():
                    return widget
            else:
                if text in message_text:
                    return widget
        return None


class ClientHelper:
    Component = JavaClass("net.minecraft.network.chat.Component")

    @staticmethod
    def disconnect(str = "Disconnected by Minescript") -> None:
        minecraft.level.disconnect(ClientHelper.Component.literal(str))

    @staticmethod
    def get_level_data() -> ClientLevelData:
        level = minecraft.level

        hardcore: bool = level.isHardcore()
        is_flat: bool = level.isFlat()
        game_time: int = level.getGameTime()
        day_time: int = level.getDayTime()
        raining: bool = level.isRaining()
        difficulty: str = ReflectionHelper.get_private_field(level, "difficulty").key
        difficulty_locked: bool = ReflectionHelper.get_private_field(level, "difficultyLocked")

        return ClientLevelData(hardcore, is_flat, game_time, day_time, raining, difficulty, difficulty_locked)

    @staticmethod
    def get_fps():
        return minecraft.getFps()
    
    @staticmethod
    def get_camera_type() -> str:
        return minecraft.options.getCameraType().name()
    
    @staticmethod
    def _get_camera() -> JavaObject:
        return minecraft.gameRenderer.getMainCamera()
    
    @staticmethod
    def get_camera_position() -> Vector3f:
        """Get current camera position"""
        camera = ClientHelper._get_camera()
        pos = camera.position()
        return (pos.getX(), pos.getY(), pos.getZ())
    
    @staticmethod
    def get_camera_block_position() -> Vector3f:
        camera = ClientHelper._get_camera()
        pos = camera.blockPosition()
        return (pos.getX(), pos.getY(), pos.getZ())
    
    @staticmethod
    def narrate_text(text: str):
        minecraft.getNarrator().saySystemNow(text)

class ClientLevelData:
    def __init__(self, hardcore: bool, is_flat: bool, game_time: int, day_time: int, raining: bool, difficulty: str, difficulty_locked: bool):
        self.hardcore = hardcore
        self.is_flat = is_flat
        self.game_time = game_time
        self.day_time = day_time
        self.raining = raining
        self.difficulty = difficulty # .key
        self.difficulty_locked = difficulty_locked

