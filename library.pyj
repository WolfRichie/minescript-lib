    @staticmethod
    def is_holding_rod() -> bool:
        hand_items: HandItems = player_hand_items()

        return hand_items.main_hand == FishingHelper.ROD or hand_items.off_hand == FishingHelper.ROD

    @staticmethod
    def is_casted() -> bool:
        return FishingHelper._get_fishing_hook() is not None

    @staticmethod
    def is_biting() -> bool | None:
